#!/usr/bin/env sh
set -eu

base_ref="${SQLWARDEN_COMMIT_WARN_BASE:-origin/main}"
threshold="${SQLWARDEN_COMMIT_WARN_THRESHOLD:-80}"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
	exit 0
fi

if ! git rev-parse --verify --quiet "$base_ref" >/dev/null; then
	exit 0
fi

merge_base="$(git merge-base HEAD "$base_ref" 2>/dev/null || true)"
if [ -z "$merge_base" ]; then
	exit 0
fi

commit_count="$(git rev-list --count "$merge_base"..HEAD 2>/dev/null || echo 0)"
next_count=$((commit_count + 1))

if [ "$next_count" -ge "$threshold" ]; then
	cat >&2 <<EOF
warning: this branch will have ${next_count} commits on top of ${base_ref} after this commit.
GitHub rebase merge can become unreliable for large PR commit stacks; consider splitting
the work or squashing fixup commits before this reaches 100 commits.

Set SQLWARDEN_COMMIT_WARN_THRESHOLD to change the warning threshold.
Set SQLWARDEN_COMMIT_WARN_BASE to compare against a different base ref.
EOF
fi

exit 0
